{
  "compilerOptions": {
    "baseUrl": "src",
    "paths": {
      "@app/*": ["app/*"],
      "@assets/*": ["assets/*"],
      "@shared/*": ["shared/*"],
      "@features/*": ["features/*"],
      "@components/*": ["shared/components/*"],
      "@utils/*": ["shared/utils/*"],
      "@constants/*": ["shared/constants/*"],
      "@routes/*": ["app/routes/*"]
    }
  },
  "include": ["src"]
}
