# Google OAuth Credentials
# Replace the placeholder with your own Google OAuth 2.0 Client ID from Google Cloud Console.
# Your Google Cloud Console OAuth setup must include http://localhost:3000/auth/google/callback as an Authorized Redirect URI.
REACT_APP_GOOGLE_CLIENT_ID=your-google-client-id-here.apps.googleusercontent.com

# Backend API base url (falls back to http://localhost:8080 if not set)
REACT_APP_API_URL=http://localhost:8080
